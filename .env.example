# Get a free Gemini API key from Google AI Studio:
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Defaults are intentionally cheap/free-tier friendly.
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_CHAT_MODEL=gemini-2.0-flash-lite
EMBEDDING_DIMENSIONS=768

# Keep this tiny for the toy app.
TOP_K=3

# Supabase pgvector storage.
# Run supabase_schema.sql once in the Supabase SQL editor first.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Pilot auth and API hardening.
# Use a long random value. This bootstrap token only creates the first real admin
# via POST /admin/users, then should be rotated or removed.
BOOTSTRAP_ADMIN_TOKEN=replace_with_long_random_bootstrap_token
JWT_SECRET_KEY=replace_with_long_random_jwt_secret
JWT_EXPIRES_MINUTES=1440
REFRESH_TOKEN_EXPIRES_DAYS=30
AUTH_DISABLED=false
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VALIDATE_CONFIG_ON_STARTUP=false
LOG_LEVEL=INFO

# Upload restrictions for source documents.
ALLOWED_UPLOAD_EXTENSIONS=pdf,txt,docx
UPLOAD_MAX_BYTES=26214400
ALLOW_DOCUMENT_REPLACE=false

# Token-based chunking defaults for rules/circulars: large enough for legal
# context, small enough to keep retrieval precise.
CHUNK_TOKENS=600
CHUNK_OVERLAP_TOKENS=100
MAX_UNIT_TOKENS=220

# FAQ chunks preserve question + answer context. Long answers repeat the
# question in every split chunk.
FAQ_CHUNK_TOKENS=650
FAQ_CHUNK_OVERLAP_TOKENS=80
FAQ_UNIT_TOKENS=260

# Procedure/process/workflow docs get slightly larger chunks and more overlap
# so multi-step procedures retain neighboring steps and section context.
PROCEDURE_CHUNK_TOKENS=720
PROCEDURE_CHUNK_OVERLAP_TOKENS=160
PROCEDURE_UNIT_TOKENS=260
